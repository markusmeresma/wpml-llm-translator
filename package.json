{
  "name": "wpml-llm-translator",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-powered translation pipeline for WPML XLIFF files with human review and safe re-import.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc -p tsconfig.json",
